{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Backend",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/backend",
            "program": "${workspaceFolder}/backend/cmd/main.go",
            "args": ["--env=.env", "--port=8080"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ],
    "compounds": [
        {
            "name": "Run Project",
            "configurations": ["Run Backend"]
        }
    ]
}
